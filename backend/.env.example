# Backend environment variables (copy to backend/.env)
PORT=4000
NODE_ENV=development

# Path to SQLite database file (relative to backend/ by default)
DB_PATH=../db/shelter.sqlite

# Logging
LOG_LEVEL=info

# CORS (front-end dev server)
CORS_ORIGIN=http://localhost:5173

# Uploads (for testing pet creation with photos).
UPLOAD_DIR=./uploads
MAX_UPLOAD_BYTES=15728640 # 15 MiB